
type Void = ();
type Any = ();

// Special duration that lasts forever
// Awaiting this duration is illegal, since it would make the video last 
// literally forever
const forever: duration = invoke_intrinsic forever_duration();

// Any awaitable construct
type Awaitable = (
    const total_duration: duration;
    const entry_frame: duration;
    prop current_frame: duration;
);
type Effect = Awaitable + ();
type Clip = Awaitable + (
    prop x: float;
    prop y: float;
    prop scale_x: float;
    prop scale_y: float;
    prop skew_x: float;
    prop skew_y: float;
    prop rotation: float;
    prop content_width: float;
    prop content_height: float;
    render: (ref Canvas) -> Void = canvas -> {
        default_render(self, canvas);
    };
);

function get_all_child_clips(target: ref clip) -> [clip] {}

type Canvas = (
    width: float;
    height: float;
    pixels: [color];
);

function copy(canvas: ref Canvas) -> Canvas {
    Canvas(
        width  = canvas.width,
        height = canvas.height,
        pixels = canvas.pixels,
    )
}

// Base rendering implementation for all clips
// todo: how on earth would this dispatch the correct overload of `render()`??
// i'm guessing i should hardcode child rendering to be a compiler built-in thing after all...
function default_render(target: ref clip, canvas: ref Canvas) {
}

// https://stackoverflow.com/questions/2353211/hsl-to-rgb-color-conversion

private function hue_to_rgb(p: float, q: float, t: float) -> float {
    if (t < 0.0) t += 1;
    if (t > 1.0) t -= 1;
    if (t < 1.0/6.0) return p + (q - p) * 6.0 * t;
    if (t < 1.0/2.0) return q;
    if (t < 2.0/3.0) return p + (q - p) * (2.0/3.0 - t) * 6.0;
    return p;
}
function hsl(h: float, s: float, l: float) -> color {
    let r: float;
    let g: float;
    let b: float;
    if (s == 0) {
        r = g = b = l;
    }
    else {
        const q = l < 0.5 ? l * (1.0 + s) : l + s - l * s;
        const p = 2.0 * l - q;
        r = hueToRgb(p, q, h + 1.0/3.0);
        g = hueToRgb(p, q, h);
        b = hueToRgb(p, q, h - 1.0/3.0);
    }
    return rgb(
        std::math::round(r * 255.0),
        std::math::round(g * 255.0),
        std::math::round(b * 255.0),
    );
}
function rgb(r: int, g: int, b: int) -> color {
    rgba(r, g, b, 255)
}
function rgba(r: int, g: int, b: int, a: int) -> color {
    invoke_intrinsic create_color(r, g, b, a)
}
