{
    "comments": {
        "lineComment": { "comment": "//" },
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}", "autoCloseBefore": ";:.,=}])>` \n\t" },
        ["[", "]"],
        ["(", ")"],
        { "open": "'", "close": "'", "notIn": ["string", "comment"] },
        { "open": "\"", "close": "\"", "notIn": ["string"] },
        { "open": "`", "close": "`", "notIn": ["string", "comment"] },
    ],
    "onEnterRules": [
        {
            "beforeText": "^\\s*///\\s+",
            "action": {
                "indent": "none",
                "appendText": "/// ",
            }
        }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["<", ">"],
        ["\"", "\""],
        ["'", "'"],
    ]
}
