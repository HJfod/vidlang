{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Vid",
	"patterns": [{ "include": "#language" }],
	"repository": {
		"language": {
			"patterns": [
				{
					"name": "comment.block.documentation.vid",
					"begin": "///",
					"end": "\n"
				},
				{
					"name": "comment.line",
					"begin": "//",
					"end": "\n"
				},
				{
					"name": "string.interpolated.vid",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"name": "constant.character.escape.vid",
							"match": "\\\\."
						},
						{
							"name": "entity.string.template.element.vid",
							"begin": "\\{",
							"end": "\\}",
							"beginCaptures": {
								"0": { "name": "punctuation.definition.template-expression.begin.vid" }
							},
							"endCaptures": {
								"0": { "name": "punctuation.definition.template-expression.end.vid" }
							},
							"patterns": [{ "include": "#language" }]
						}
					]
				},
				{
					"name": "keyword.control.vid",
					"match": "\\b(let|const|type|function|clip|trait|impl|struct|private|public|module|using|if|then|else|while|for|in|loop|await|return|yield|and|or|mod|unit|get|set|intrinsic|typeof|oneof|struct|enum)\\b"
				},
				{
					"name": "keyword.other.vid",
					"match": "\\b(ref)\\b"
				},
				{
					"name": "entity.name.tag.vid",
					"match": "@\\p{XID_Start}\\p{XID_Continue}*"
				},
				{
					"name": "keyword.operator.vid",
					"match": "(:=|[\\+\\-\\*\\/=<>\\^\\|\\&\\!%])"
				},
				{
					"name": "punctuation.vid",
					"match": "(->)|\\.|;|,|:|\\?|#"
				},
				{
					"name": "constant.numeric.vid",
					"match": "\\b([0-9]+(\\.[0-9]+)?(\\p{XID_Start}\\p{XID_Continue}*)?)\\b"
				},
				{
					"name": "constant.numeric.vid",
					"match": "0x[0-9A-Fa-f]+"
				},
				{
					"name": "constant.language.vid",
					"match": "\\b(true|false|none|self)\\b"
				},
				{
					"name": "variable.other.constant.vid",
					"match": "\\b(\\p{Uppercase}\\p{Uppercase}+)\\b"
				},
				{
					"name": "variable.other.constant.vid",
					"match": "(?<=const\\s+)\\b(\\p{XID_Start}\\p{XID_Continue}*)\\b"
				},
				{
					"match": "\\b(bool|int|float|string|duration)\\b",
					"name": "entity.name.type.language.vid"
				},
				{
					"match": "\\b(\\p{XID_Start}\\p{XID_Continue}*)(?=\\()",
					"captures": {
						"1": {
							"name": "entity.name.function.vid"
						}
					}
				},
				{
					"match": "(?<=(:|->)\\s*)(\\p{XID_Start}\\p{XID_Continue}*)",
					"name": "entity.name.type.vid"
				},
				{
					"match": "(\\p{XID_Start}\\p{XID_Continue}*)(?=\\s*::)",
					"name": "entity.name.type.vid"
				},
                {
                    "match": "\\p{Uppercase}\\p{XID_Continue}*",
                    "name": "entity.name.type.vid"
                },
				{
					"match": "\\b(\\p{XID_Start}\\p{XID_Continue}*)\\b",
					"captures": {
						"1": {
							"name": "entity.name.variable.vid"
						}
					}
				},
				{
					"begin": "\\(",
					"end": "\\)",
					"beginCaptures": {
						"0": { "name": "punctuation.paren.open" }
					},
					"endCaptures": {
						"0": { "name": "punctuation.paren.close" }
					},
					"name": "expression.group",
					"patterns": [{ "include": "#language" }]
				},
				{
					"begin": "\\{",
					"end": "\\}",
					"beginCaptures": {
						"0": { "name": "punctuation.paren.open" }
					},
					"endCaptures": {
						"0": { "name": "punctuation.paren.close" }
					},
					"name": "expression.group",
					"patterns": [{ "include": "#language" }]
				},
				{
					"begin": "\\[",
					"end": "\\]",
					"beginCaptures": {
						"0": { "name": "punctuation.paren.open" }
					},
					"endCaptures": {
						"0": { "name": "punctuation.paren.close" }
					},
					"name": "expression.group",
					"patterns": [{ "include": "#language" }]
				}
			]
		}
	},
	"scopeName": "source.vid"
}
